// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SystemRole {
  ADMIN
  DEAN
  PROGRAM_HEAD
  FACULTY
  STUDENT
  ALUMNI
  INDUSTRY_PARTNER
}

enum AcademicSemester {
  FIRST  @map("1ST")
  SECOND @map("2ND")
  SUMMER

  @@map("academic_semester")
}

enum AcademicTerm {
  FIRST_TERM
  SECOND_TERM

  @@map("academic_term")
}

enum YearLevel {
  FIRST_YEAR
  SECOND_YEAR
  THIRD_YEAR
  FOURTH_YEAR

  @@map("year_level")
}

enum InviteStatus {
  DRAFT
  SENT
  ACCEPTED
  REVOKED
}

enum CourseScope {
  GENERAL_EDUCATION
  PROGRAM_SPECIFIC
  MAJOR_SPECIFIC
}

enum DeploymentStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ResponseStatus {
  IN_PROGRESS
  SUBMITTED
}

enum DeploymentType {
  COURSE_BOUND
  CENTRAL
}

enum TargetStakeholder {
  STUDENT
  ALUMNI
  INDUSTRY_PARTNER
}

enum EvaluationTemplateType {
  PROGRAM_WIDE
  COURSE_BOUND
}

enum StudentSection {
  MORNING
  AFTERNOON
  EVENING

  @@map("student_section")
}

enum EnrollmentSource {
  ONBOARDING
  ROLLOVER
  ADMIN

  @@map("enrollment_source")
}

// ============================================================================
// Academic Calendar Entities
// ============================================================================

model SchoolYear {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  start_date  DateTime? @db.Date
  end_date    DateTime? @db.Date
  is_archived Boolean  @default(false)
  archived_by String?  @db.Uuid
  archived_at DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  term_instances    AcademicTermInstance[]
  archived_by_user  User?    @relation("ArchivedSchoolYears", fields: [archived_by], references: [id], onDelete: SetNull)

  @@map("school_years")
}

model AcademicTermInstance {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  school_year_id  String           @db.Uuid
  semester        AcademicSemester
  term            AcademicTerm?
  start_date      DateTime?        @db.Date
  end_date        DateTime?        @db.Date
  is_active       Boolean          @default(false)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  school_year SchoolYear @relation(fields: [school_year_id], references: [id], onDelete: Cascade)
  student_enrollments StudentEnrollment[]
  course_assignments CourseAssignment[]
  course_bound_evaluations CourseBoundEvaluation[]
  central_deployments CentralDeployment[]

  // Prisma cannot express NULLS NOT DISTINCT; the actual unique constraint is managed via Supabase migration
  @@index([school_year_id, semester, term])
  @@index([is_active])
  @@map("academic_term_instances")
}

model StudentEnrollment {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_user_id   String           @db.Uuid
  term_instance_id  String           @db.Uuid
  program_id        String           @db.Uuid
  major_id          String?          @db.Uuid
  year_level        YearLevel
  section           StudentSection?
  source            EnrollmentSource
  is_active         Boolean          @default(true)
  created_by        String?          @db.Uuid
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  student      User                @relation(fields: [student_user_id], references: [id], onDelete: Cascade)
  term         AcademicTermInstance @relation(fields: [term_instance_id], references: [id], onDelete: Cascade)
  program      Program             @relation(fields: [program_id], references: [id], onDelete: Restrict)
  major        Major?              @relation(fields: [major_id], references: [id], onDelete: SetNull)
  creator      User?               @relation("EnrollmentCreator", fields: [created_by], references: [id], onDelete: SetNull)

  @@unique([student_user_id, term_instance_id])
  @@index([term_instance_id, program_id, year_level, section])
  @@index([is_active])
  @@map("student_enrollments")
}

model CourseAssignment {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  term_instance_id  String   @db.Uuid
  faculty_id        String   @db.Uuid
  course_id         String   @db.Uuid
  program_id        String   @db.Uuid
  year_level        YearLevel
  section           StudentSection?
  assigned_by       String?  @db.Uuid
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  term_instance AcademicTermInstance @relation(fields: [term_instance_id], references: [id], onDelete: Cascade)
  faculty       User                 @relation("faculty", fields: [faculty_id], references: [id], onDelete: Cascade)
  course        Course               @relation(fields: [course_id], references: [id], onDelete: Cascade)
  program       Program              @relation(fields: [program_id], references: [id], onDelete: Restrict)
  assigner      User?                @relation("AssignmentAssigner", fields: [assigned_by], references: [id], onDelete: SetNull)
  course_bound_evaluations CourseBoundEvaluation[]

  // Unique constraint: one assignment per faculty/course/program/year/section per term
  // NULLS NOT DISTINCT enforced in SQL migration; mirrored here as index
  @@index([term_instance_id, course_id, faculty_id, program_id, year_level, section])
  @@index([term_instance_id, faculty_id])
  @@index([term_instance_id, course_id])
  @@index([is_active])
  @@map("course_assignments")
}

// ============================================================================
// Core Academic Entities
// ============================================================================

model User {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auth_user_id         String?                 @unique @db.Uuid
  email                String                  @unique
  first_name           String
  last_name            String
  is_active            Boolean                 @default(true)
  created_at           DateTime                @default(now())
  updated_at           DateTime                @updatedAt

  roles                UserRole[]
  student_profile      StudentAcademicProfile?
  course_evaluations   CourseBoundEvaluation[]
  evaluation_assignments  EvaluationAssignment[]
  responses            Response[]
  created_cilos        CILO[]
  faculty_program_affiliations FacultyProgramAffiliation[]
  program_head_assignments ProgramHeadAssignment[]
  created_external_invites ExternalStakeholderInvite[] @relation("ExternalInviteCreator")
  industry_partner_profile IndustryPartnerProfile?
  alumni_profile       AlumniProfile?
  faculty_owned_templates InstrumentTemplate[] @relation("FacultyOwnedInstrumentTemplates")
  archived_school_years SchoolYear[] @relation("ArchivedSchoolYears")
  enrollments            StudentEnrollment[]
  created_enrollments    StudentEnrollment[] @relation("EnrollmentCreator")
  course_assignments     CourseAssignment[] @relation("faculty")
  created_assignments    CourseAssignment[] @relation("AssignmentAssigner")

  @@map("users")
}

model UserRole {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String     @unique @db.Uuid
  role        SystemRole
  assigned_at DateTime   @default(now())

  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_roles")
}

model Program {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  majors               Major[]
  courses              Course[]
  student_profiles     StudentAcademicProfile[]
  gos                  GO[]
  course_evaluations   CourseBoundEvaluation[]
  faculty_program_affiliations FacultyProgramAffiliation[]
  program_head_assignments ProgramHeadAssignment[]
  course_bound_targets CourseBoundEvaluationTarget[]
  central_deployments  CentralDeployment[]
  external_stakeholder_invites ExternalStakeholderInvite[]
  instrument_templates InstrumentTemplate[]
  bound_instrument_templates InstrumentTemplate[] @relation("BoundInstrumentTemplateProgram")
  industry_partner_profiles IndustryPartnerProfile[]
  alumni_profiles      AlumniProfile[]
  student_enrollments    StudentEnrollment[]
  course_assignments     CourseAssignment[]

  @@map("programs")
}

model Major {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  program_id  String   @db.Uuid
  name        String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  program              Program                  @relation(fields: [program_id], references: [id], onDelete: Cascade)
  courses              Course[]
  student_profiles     StudentAcademicProfile[]
  alumni_profiles      AlumniProfile[]
  course_evaluations   CourseBoundEvaluation[]
  central_deployments  CentralDeployment[]
  bound_instrument_templates InstrumentTemplate[] @relation("BoundInstrumentTemplateMajor")
  student_enrollments    StudentEnrollment[]

  @@unique([program_id, name])
  @@map("majors")
}

model Course {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String      @unique
  title        String
  description  String?
  program_id   String?     @db.Uuid
  major_id     String?     @db.Uuid
  course_scope CourseScope @default(PROGRAM_SPECIFIC)
  is_active    Boolean     @default(true)
  created_at   DateTime    @default(now())
  updated_at   DateTime   @updatedAt

  program      Program?    @relation(fields: [program_id], references: [id], onDelete: SetNull)
  major        Major?      @relation(fields: [major_id], references: [id], onDelete: SetNull)
  cilos        CILO[]
  evaluations  CourseBoundEvaluation[]
  bound_instrument_templates InstrumentTemplate[] @relation("BoundInstrumentTemplateCourse")
  course_assignments CourseAssignment[]

  @@map("courses")
}

model StudentAcademicProfile {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String         @unique @db.Uuid
  program_id        String         @db.Uuid
  major_id          String?        @db.Uuid
  student_id_number String?
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  // Phase 9: academic_year, year_level, section removed - now in StudentEnrollment ledger
  // Keeping program_id, major_id, student_id_number as static cohort identifiers

  user              User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  program           Program    @relation(fields: [program_id], references: [id], onDelete: Restrict)
  major             Major?     @relation(fields: [major_id], references: [id], onDelete: SetNull)

  @@map("student_academic_profiles")
}

// ============================================================================
// Outcomes Management
// ============================================================================

model GO {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String
  description String
  order       Int      @default(0)
  program_id  String   @db.Uuid
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  program       Program        @relation(fields: [program_id], references: [id], onDelete: Cascade)
  cilo_mappings CILOMapping[]

  @@unique([program_id, code])
  @@map("gos")
}

model CILO {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description   String
  course_id     String   @db.Uuid
  created_by    String   @db.Uuid
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  course        Course        @relation(fields: [course_id], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [created_by], references: [id], onDelete: Restrict)
  cilo_mappings CILOMapping[]
  question_bindings CourseBoundCiloQuestionBinding[]
  template_question_bindings InstrumentTemplateCiloQuestionBinding[]

  @@map("cilos")
}

model CILOMapping {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cilo_id    String   @db.Uuid
  go_id      String   @db.Uuid
  created_at DateTime @default(now())

  cilo       CILO   @relation(fields: [cilo_id], references: [id], onDelete: Cascade)
  go         GO     @relation(fields: [go_id], references: [id], onDelete: Cascade)

  @@map("cilo_mappings")
}

// ============================================================================
// Instruments and Responses
// ============================================================================

model InstrumentTemplate {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String   @unique // CILO_EVAL, EXIT_SURVEY, ALUMNI_EVAL, INDUSTRY_EVAL
  name                  String
  description           String?
  template_type         EvaluationTemplateType @default(PROGRAM_WIDE)
  structure             Json     // JSON defining sections and items
  is_active             Boolean  @default(true)
  is_faculty_accessible Boolean  @default(false)
  program_id            String?  @db.Uuid
  faculty_owner_id      String?  @db.Uuid
  source_template_id    String?  @db.Uuid
  bound_course_id       String?  @db.Uuid
  bound_program_id      String?  @db.Uuid
  bound_major_id        String?  @db.Uuid
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  program               Program? @relation(fields: [program_id], references: [id], onDelete: SetNull)
  faculty_owner         User?    @relation("FacultyOwnedInstrumentTemplates", fields: [faculty_owner_id], references: [id], onDelete: Cascade)
  source_template       InstrumentTemplate? @relation("InstrumentTemplateCopies", fields: [source_template_id], references: [id], onDelete: SetNull)
  derived_templates     InstrumentTemplate[] @relation("InstrumentTemplateCopies")
  bound_course          Course?  @relation("BoundInstrumentTemplateCourse", fields: [bound_course_id], references: [id], onDelete: SetNull)
  bound_program         Program? @relation("BoundInstrumentTemplateProgram", fields: [bound_program_id], references: [id], onDelete: SetNull)
  bound_major           Major?   @relation("BoundInstrumentTemplateMajor", fields: [bound_major_id], references: [id], onDelete: SetNull)
  versions              InstrumentVersion[]
  template_cilo_question_bindings InstrumentTemplateCiloQuestionBinding[]

  @@map("instrument_templates")
}

model InstrumentVersion {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  template_id        String   @db.Uuid
  version_number     Int
  structure_snapshot Json     // Frozen JSON of the structure for this version
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  template          InstrumentTemplate       @relation(fields: [template_id], references: [id], onDelete: Cascade)
  course_bounds     CourseBoundEvaluation[]
  central_insts     CentralDeployment[]

  @@unique([template_id, version_number])
  @@map("instrument_versions")
}

model CourseBoundEvaluation {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instrument_version_id String   @db.Uuid
  deployment_name       String
  course_id             String   @db.Uuid
  program_id            String   @db.Uuid
  major_id              String?  @db.Uuid
  faculty_id            String   @db.Uuid
  section               StudentSection?
  cilos_snapshot        Json     // Snapshot of CILOs at time of publishing
  course_info_snapshot  Json     // Snapshot of course info at time of publishing
  activation_at         DateTime?
  deadline_at           DateTime?
  status                DeploymentStatus
  published_at          DateTime?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  // Phase 9: term_instance_id is now the source of truth
  term_instance_id      String   @db.Uuid
  course_assignment_id  String?  @db.Uuid

  instrument            InstrumentVersion @relation(fields: [instrument_version_id], references: [id], onDelete: Restrict)
  course                Course            @relation(fields: [course_id], references: [id], onDelete: Restrict)
  program               Program           @relation(fields: [program_id], references: [id], onDelete: Restrict)
  major                 Major?            @relation(fields: [major_id], references: [id], onDelete: SetNull)
  faculty               User              @relation(fields: [faculty_id], references: [id], onDelete: Restrict)
  term_instance         AcademicTermInstance @relation(fields: [term_instance_id], references: [id], onDelete: Restrict)
  course_assignment     CourseAssignment?    @relation(fields: [course_assignment_id], references: [id], onDelete: SetNull)
  assignments           EvaluationAssignment[] @relation("CourseBoundAssignments")
  targets               CourseBoundEvaluationTarget[]
  cilo_question_bindings CourseBoundCiloQuestionBinding[]

  // Phase 9: Unique constraint on term_instance + course + faculty + section (NULLS NOT DISTINCT in SQL)
  // The actual constraint is managed via Supabase migration.
  @@index([term_instance_id, course_id, faculty_id, section])
  @@index([course_assignment_id])
  @@map("course_bound_evaluations")
}

model CourseBoundCiloQuestionBinding {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_bound_evaluation_id String   @db.Uuid
  cilo_id                    String?  @db.Uuid
  cilo_description_snapshot  String
  section_key                String
  item_key                   String
  question_prompt_snapshot   String
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  course_bound_evaluation    CourseBoundEvaluation @relation(fields: [course_bound_evaluation_id], references: [id], onDelete: Cascade)
  cilo                       CILO?                 @relation(fields: [cilo_id], references: [id], onDelete: SetNull)
  quantitative_items         QuantitativeResponseItem[]

  @@unique([course_bound_evaluation_id, cilo_id], map: "course_bound_cilo_question_bindings_eval_cilo_key")
  @@unique([course_bound_evaluation_id, section_key, item_key], map: "course_bound_cilo_question_bindings_eval_question_key")
  @@map("course_bound_cilo_question_bindings")
}

model InstrumentTemplateCiloQuestionBinding {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  template_id                String   @db.Uuid
  cilo_id                    String?  @db.Uuid
  cilo_description_snapshot  String
  section_key                String
  item_key                   String
  question_prompt_snapshot   String
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  template                   InstrumentTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  cilo                       CILO?              @relation(fields: [cilo_id], references: [id], onDelete: SetNull)

  @@unique([template_id, cilo_id], map: "itcqb_template_cilo_key")
  @@unique([template_id, section_key, item_key], map: "itcqb_template_question_key")
  @@map("instrument_template_cilo_question_bindings")
}

model FacultyProgramAffiliation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faculty_id String   @db.Uuid
  program_id String   @db.Uuid
  is_primary Boolean  @default(false)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  faculty    User     @relation(fields: [faculty_id], references: [id], onDelete: Cascade)
  program    Program  @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@unique([faculty_id, program_id])
  @@map("faculty_program_affiliations")
}

model ProgramHeadAssignment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  program_head_id String   @db.Uuid
  program_id      String   @db.Uuid
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  program_head    User     @relation(fields: [program_head_id], references: [id], onDelete: Cascade)
  program         Program  @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@unique([program_head_id, program_id])
  @@map("program_head_assignments")
}

model CourseBoundEvaluationTarget {
  id                         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_bound_evaluation_id String     @db.Uuid
  program_id                 String     @db.Uuid
  year_level                 YearLevel?
  created_at                 DateTime   @default(now())
  updated_at                 DateTime   @updatedAt

  course_bound_evaluation    CourseBoundEvaluation @relation(fields: [course_bound_evaluation_id], references: [id], onDelete: Cascade)
  program                    Program               @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@unique([course_bound_evaluation_id, program_id, year_level])
  @@map("course_bound_evaluation_targets")
}

model CentralDeployment {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instrument_version_id String            @db.Uuid
  deployment_name       String
  program_id            String?           @db.Uuid
  major_id              String?           @db.Uuid
  year_level            YearLevel?
  target_stakeholder    TargetStakeholder
  term                  AcademicTerm?
  activation_at         DateTime?
  deadline_at           DateTime?
  status                DeploymentStatus
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  // Phase 9: term_instance_id is now required (source of truth)
  term_instance_id      String            @db.Uuid
  term_instance         AcademicTermInstance @relation(fields: [term_instance_id], references: [id], onDelete: Restrict)

  instrument            InstrumentVersion @relation(fields: [instrument_version_id], references: [id], onDelete: Restrict)
  program               Program?          @relation(fields: [program_id], references: [id], onDelete: SetNull)
  major                 Major?            @relation(fields: [major_id], references: [id], onDelete: SetNull)
  assignments           EvaluationAssignment[] @relation("CentralDeployments")

  @@index([term_instance_id])
  @@map("central_deployments")
}

model ExternalStakeholderInvite {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String
  role             SystemRole
  program_id       String?      @db.Uuid
  invited_by       String?      @db.Uuid
  invitee_name     String?
  company_name     String?
  note             String?
  status           InviteStatus @default(DRAFT)
  sent_at          DateTime?
  accepted_at      DateTime?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  inviter          User?        @relation("ExternalInviteCreator", fields: [invited_by], references: [id], onDelete: SetNull)
  program          Program?     @relation(fields: [program_id], references: [id], onDelete: SetNull)

  @@index([role, status])
  @@unique([email, role, program_id])
  @@map("external_stakeholder_invites")
}

model EvaluationAssignment {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_bound_id         String?  @db.Uuid
  central_deployment_id   String?  @db.Uuid
  respondent_id           String   @db.Uuid
  assigned_at             DateTime @default(now())

  course_bound            CourseBoundEvaluation? @relation("CourseBoundAssignments", fields: [course_bound_id], references: [id], onDelete: Cascade)
  central_deployment      CentralDeployment?     @relation("CentralDeployments", fields: [central_deployment_id], references: [id], onDelete: Cascade)
  respondent              User                   @relation(fields: [respondent_id], references: [id], onDelete: Restrict)
  response                Response?

  @@map("evaluation_assignments")
}

model Response {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignment_id   String   @unique @db.Uuid
  respondent_id   String   @db.Uuid
  deployment_type DeploymentType
  deployment_id   String   @db.Uuid
  status          ResponseStatus
  submitted_at    DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  assignment      EvaluationAssignment         @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  respondent      User                         @relation(fields: [respondent_id], references: [id], onDelete: Restrict)
  quant_items     QuantitativeResponseItem[]
  qual_items      QualitativeResponseItem[]

  @@map("responses")
}

model IndustryPartnerProfile {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String             @unique @db.Uuid
  company_name        String
  position            String?
  program_id          String?            @db.Uuid
  verification_status VerificationStatus @default(PENDING)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  user                User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  program             Program?           @relation(fields: [program_id], references: [id], onDelete: SetNull)

  @@map("industry_partner_profiles")
}

model QuantitativeResponseItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  response_id   String   @db.Uuid
  cilo_question_binding_id String? @db.Uuid
  section_key   String
  item_key      String
  rating_value  Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  response      Response @relation(fields: [response_id], references: [id], onDelete: Cascade)
  cilo_question_binding CourseBoundCiloQuestionBinding? @relation(fields: [cilo_question_binding_id], references: [id], onDelete: SetNull)

  @@map("quantitative_response_items")
}

model QualitativeResponseItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  response_id   String   @db.Uuid
  section_key   String
  prompt_key    String
  text_content  String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  response      Response @relation(fields: [response_id], references: [id], onDelete: Cascade)

  @@map("qualitative_response_items")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("verification_status")
}

model AlumniProfile {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String             @unique @db.Uuid
  graduation_year     Int
  program_id          String             @db.Uuid
  major_id            String?            @db.Uuid
  verification_status VerificationStatus @default(PENDING)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  user                User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  program             Program            @relation(fields: [program_id], references: [id], onDelete: Restrict)
  major               Major?             @relation(fields: [major_id], references: [id], onDelete: SetNull)

  @@map("alumni_profiles")
}
