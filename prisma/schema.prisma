// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SystemRole {
  ADMIN
  DEAN
  PROGRAM_HEAD
  FACULTY
  STUDENT
  ALUMNI
  INDUSTRY_PARTNER
}

enum AcademicSemester {
  FIRST  @map("1ST")
  SECOND @map("2ND")
  SUMMER

  @@map("academic_semester")
}

enum AcademicTerm {
  FIRST_TERM
  SECOND_TERM

  @@map("academic_term")
}

enum InviteStatus {
  DRAFT
  SENT
  ACCEPTED
  REVOKED
}

enum CourseScope {
  GENERAL_EDUCATION
  PROGRAM_SPECIFIC
}

enum DeploymentStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ResponseStatus {
  IN_PROGRESS
  SUBMITTED
}

enum DeploymentType {
  COURSE_BOUND
  CENTRAL
}

enum TargetStakeholder {
  GRADUATING_STUDENT
  ALUMNI
  INDUSTRY_PARTNER
}

// ============================================================================
// Core Academic Entities
// ============================================================================

model User {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String                  @unique
  first_name           String
  last_name            String
  avatar_url           String?
  is_active            Boolean                 @default(true)
  created_at           DateTime                @default(now())
  updated_at           DateTime                @updatedAt

  roles                UserRole[]
  student_profile      StudentAcademicProfile?
  course_evaluations   CourseBoundEvaluation[]
  evaluation_assignments  EvaluationAssignment[]
  responses            Response[]
  created_cilos        CILO[]
  faculty_program_affiliations FacultyProgramAffiliation[]
  program_head_assignments ProgramHeadAssignment[]
  created_external_invites ExternalStakeholderInvite[] @relation("ExternalInviteCreator")
  industry_partner_profile IndustryPartnerProfile?

  @@map("users")
}

model UserRole {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String     @db.Uuid
  role        SystemRole
  assigned_at DateTime   @default(now())

  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role])
  @@map("user_roles")
}

model Program {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  majors               Major[]
  courses              Course[]
  student_profiles     StudentAcademicProfile[]
  gos                  GO[]
  course_evaluations   CourseBoundEvaluation[]
  faculty_program_affiliations FacultyProgramAffiliation[]
  program_head_assignments ProgramHeadAssignment[]
  course_bound_targets CourseBoundEvaluationTarget[]
  central_deployments  CentralDeployment[]
  external_stakeholder_invites ExternalStakeholderInvite[]
  instrument_templates InstrumentTemplate[]
  industry_partner_profiles IndustryPartnerProfile[]

  @@map("programs")
}

model Major {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  program_id  String   @db.Uuid
  name        String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  program              Program                  @relation(fields: [program_id], references: [id], onDelete: Cascade)
  courses              Course[]
  student_profiles     StudentAcademicProfile[]
  course_evaluations   CourseBoundEvaluation[]
  central_deployments  CentralDeployment[]

  @@unique([program_id, name])
  @@map("majors")
}

model Course {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String      @unique
  title        String
  description  String?
  program_id   String?     @db.Uuid
  major_id     String?     @db.Uuid
  course_scope CourseScope @default(PROGRAM_SPECIFIC)
  is_active    Boolean     @default(true)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  program      Program?    @relation(fields: [program_id], references: [id], onDelete: SetNull)
  major        Major?      @relation(fields: [major_id], references: [id], onDelete: SetNull)
  cilos        CILO[]
  evaluations  CourseBoundEvaluation[]

  @@map("courses")
}

model YearLevel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique // 1st Year, 2nd Year, etc.
  order       Int

  student_profiles StudentAcademicProfile[]
  course_bound_targets CourseBoundEvaluationTarget[]
  central_deployments CentralDeployment[]

  @@map("year_levels")
}

model StudentAcademicProfile {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @unique @db.Uuid
  program_id        String   @db.Uuid
  major_id          String?  @db.Uuid
  year_level_id     String   @db.Uuid
  student_id_number String?
  academic_year     String
  is_graduating     Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user              User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  program           Program    @relation(fields: [program_id], references: [id], onDelete: Restrict)
  major             Major?     @relation(fields: [major_id], references: [id], onDelete: SetNull)
  year_level        YearLevel  @relation(fields: [year_level_id], references: [id], onDelete: Restrict)

  @@map("student_academic_profiles")
}

// ============================================================================
// Outcomes Management
// ============================================================================

model GO {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String
  description String
  program_id  String   @db.Uuid
  order       Int
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  program       Program        @relation(fields: [program_id], references: [id], onDelete: Cascade)
  cilo_mappings CILOMapping[]

  @@unique([program_id, code])
  @@map("gos")
}

model CILO {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description   String
  course_id     String   @db.Uuid
  order         Int
  academic_term String
  created_by    String   @db.Uuid
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  course        Course        @relation(fields: [course_id], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [created_by], references: [id], onDelete: Restrict)
  cilo_mappings CILOMapping[]

  @@unique([course_id, academic_term, order])
  @@map("cilos")
}

model CILOMapping {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cilo_id    String   @db.Uuid
  go_id      String   @db.Uuid
  created_at DateTime @default(now())

  cilo       CILO   @relation(fields: [cilo_id], references: [id], onDelete: Cascade)
  go         GO     @relation(fields: [go_id], references: [id], onDelete: Cascade)

  @@map("cilo_mappings")
}

// ============================================================================
// Instruments and Responses
// ============================================================================

model InstrumentTemplate {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String   @unique // CILO_EVAL, EXIT_SURVEY, ALUMNI_EVAL, INDUSTRY_EVAL
  name                  String
  description           String?
  structure             Json     // JSON defining sections and items
  is_active             Boolean  @default(true)
  is_faculty_accessible Boolean  @default(false)
  program_id            String?  @db.Uuid
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  program               Program? @relation(fields: [program_id], references: [id], onDelete: SetNull)
  versions              InstrumentVersion[]

  @@map("instrument_templates")
}

model InstrumentVersion {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  template_id        String   @db.Uuid
  version_number     Int
  structure_snapshot Json     // Frozen JSON of the structure for this version
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  template          InstrumentTemplate       @relation(fields: [template_id], references: [id], onDelete: Cascade)
  course_bounds     CourseBoundEvaluation[]
  central_insts     CentralDeployment[]

  @@unique([template_id, version_number])
  @@map("instrument_versions")
}

model CourseBoundEvaluation {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instrument_version_id String   @db.Uuid
  course_id             String   @db.Uuid
  program_id            String   @db.Uuid
  major_id              String?  @db.Uuid
  semester              AcademicSemester
  term                  AcademicTerm
  academic_year         String
  faculty_id            String   @db.Uuid
  cilos_snapshot        Json     // Snapshot of CILOs at time of publishing
  course_info_snapshot  Json     // Snapshot of course info at time of publishing
  activation_at         DateTime?
  deadline_at           DateTime?
  status                DeploymentStatus
  published_at          DateTime?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  instrument            InstrumentVersion @relation(fields: [instrument_version_id], references: [id], onDelete: Restrict)
  course                Course            @relation(fields: [course_id], references: [id], onDelete: Restrict)
  program               Program           @relation(fields: [program_id], references: [id], onDelete: Restrict)
  major                 Major?            @relation(fields: [major_id], references: [id], onDelete: SetNull)
  faculty               User              @relation(fields: [faculty_id], references: [id], onDelete: Restrict)
  assignments           EvaluationAssignment[] @relation("CourseBoundAssignments")
  targets               CourseBoundEvaluationTarget[]

  @@unique([course_id, academic_year, semester, term])
  @@map("course_bound_evaluations")
}

model FacultyProgramAffiliation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faculty_id String   @db.Uuid
  program_id String   @db.Uuid
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  faculty    User     @relation(fields: [faculty_id], references: [id], onDelete: Cascade)
  program    Program  @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@unique([faculty_id, program_id])
  @@map("faculty_program_affiliations")
}

model ProgramHeadAssignment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  program_head_id String   @db.Uuid
  program_id      String   @db.Uuid
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  program_head    User     @relation(fields: [program_head_id], references: [id], onDelete: Cascade)
  program         Program  @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@unique([program_head_id, program_id])
  @@map("program_head_assignments")
}

model CourseBoundEvaluationTarget {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_bound_evaluation_id String   @db.Uuid
  program_id                 String   @db.Uuid
  year_level_id              String?  @db.Uuid
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  course_bound_evaluation    CourseBoundEvaluation @relation(fields: [course_bound_evaluation_id], references: [id], onDelete: Cascade)
  program                    Program               @relation(fields: [program_id], references: [id], onDelete: Cascade)
  year_level                 YearLevel?            @relation(fields: [year_level_id], references: [id], onDelete: SetNull)

  @@unique([course_bound_evaluation_id, program_id, year_level_id])
  @@map("course_bound_evaluation_targets")
}

model CentralDeployment {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instrument_version_id String   @db.Uuid
  program_id            String?  @db.Uuid
  major_id              String?  @db.Uuid
  year_level_id         String?  @db.Uuid
  target_stakeholder    TargetStakeholder
  academic_year         String
  semester              AcademicSemester
  activation_at         DateTime?
  deadline_at           DateTime?
  status                DeploymentStatus
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  instrument            InstrumentVersion @relation(fields: [instrument_version_id], references: [id], onDelete: Restrict)
  program               Program?          @relation(fields: [program_id], references: [id], onDelete: SetNull)
  major                 Major?            @relation(fields: [major_id], references: [id], onDelete: SetNull)
  year_level            YearLevel?        @relation(fields: [year_level_id], references: [id], onDelete: SetNull)
  assignments           EvaluationAssignment[] @relation("CentralDeployments")

  @@map("central_deployments")
}

model ExternalStakeholderInvite {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String
  role             SystemRole
  program_id       String?      @db.Uuid
  invited_by       String?      @db.Uuid
  invitee_name     String?
  company_name     String?
  note             String?
  status           InviteStatus @default(DRAFT)
  sent_at          DateTime?
  accepted_at      DateTime?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  inviter          User?        @relation("ExternalInviteCreator", fields: [invited_by], references: [id], onDelete: SetNull)
  program          Program?     @relation(fields: [program_id], references: [id], onDelete: SetNull)

  @@index([role, status])
  @@unique([email, role, program_id])
  @@map("external_stakeholder_invites")
}

model EvaluationAssignment {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_bound_id         String?  @db.Uuid
  central_deployment_id   String?  @db.Uuid
  respondent_id           String   @db.Uuid
  assigned_at             DateTime @default(now())

  course_bound            CourseBoundEvaluation? @relation("CourseBoundAssignments", fields: [course_bound_id], references: [id], onDelete: Cascade)
  central_deployment      CentralDeployment?     @relation("CentralDeployments", fields: [central_deployment_id], references: [id], onDelete: Cascade)
  respondent              User                   @relation(fields: [respondent_id], references: [id], onDelete: Restrict)
  response                Response?

  @@map("evaluation_assignments")
}

model Response {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignment_id   String   @unique @db.Uuid
  respondent_id   String   @db.Uuid
  deployment_type DeploymentType
  deployment_id   String   @db.Uuid
  status          ResponseStatus
  submitted_at    DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  assignment      EvaluationAssignment         @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  respondent      User                         @relation(fields: [respondent_id], references: [id], onDelete: Restrict)
  quant_items     QuantitativeResponseItem[]
  qual_items      QualitativeResponseItem[]

  @@map("responses")
}

model IndustryPartnerProfile {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @unique @db.Uuid
  company_name  String
  position      String?
  program_id    String?  @db.Uuid
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  program       Program? @relation(fields: [program_id], references: [id], onDelete: SetNull)

  @@map("industry_partner_profiles")
}

model QuantitativeResponseItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  response_id   String   @db.Uuid
  section_key   String
  item_key      String
  rating_value  Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  response      Response @relation(fields: [response_id], references: [id], onDelete: Cascade)

  @@map("quantitative_response_items")
}

model QualitativeResponseItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  response_id   String   @db.Uuid
  section_key   String
  prompt_key    String
  text_content  String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  response      Response @relation(fields: [response_id], references: [id], onDelete: Cascade)

  @@map("qualitative_response_items")
}
